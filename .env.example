TELEGRAM_BOT_TOKEN=your_token_here

# ID чата, в котором бот следит за матом. Если пусто — работает во всех чатах.
CHAT_ID=-1001234567890

# ID юзеров, за которыми следить (через запятую). Если пусто — следит за всеми.
USER_IDS=111111111,222222222

# ID админов, которые могут управлять ботом через команды (через запятую).
ADMIN_IDS=111111111
